
{
  "entities": {
    "Team": {
      "title": "Team",
      "type": "object",
      "description": "Represents a sports team or season. Acts as the root container for all data.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "createdAt", "updatedAt"]
    },
    "Player": {
      "title": "Player",
      "type": "object",
      "description": "Represents an individual player in a specific season.",
      "properties": {
        "id": { "type": "string" },
        "teamId": { "type": "string" },
        "teamOwnerId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "stats": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "teamId", "teamOwnerId", "name", "role"]
    },
    "Match": {
      "title": "Match",
      "type": "object",
      "description": "Represents a match event.",
      "properties": {
        "id": { "type": "string" },
        "teamId": { "type": "string" },
        "teamOwnerId": { "type": "string" },
        "opponent": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "isHome": { "type": "boolean" },
        "type": { "type": "string" },
        "duration": { "type": "number" },
        "status": { "type": "string" },
        "result": { "type": "object" },
        "notes": { "type": "string" }
      },
      "required": ["id", "teamId", "teamOwnerId", "opponent", "date", "status"]
    },
    "MatchEvent": {
      "title": "MatchEvent",
      "type": "object",
      "description": "Events occurred during a match (goals, cards, substitutions).",
      "properties": {
        "id": { "type": "string" },
        "matchId": { "type": "string" },
        "teamOwnerId": { "type": "string" },
        "type": { "type": "string" },
        "team": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "subOutPlayerId": { "type": "string" },
        "subOutPlayerName": { "type": "string" },
        "assistPlayerId": { "type": "string" },
        "assistPlayerName": { "type": "string" },
        "minute": { "type": "number" },
        "period": { "type": "string" }
      },
      "required": ["id", "matchId", "teamOwnerId", "type", "team", "minute", "period"]
    },
    "MatchLineup": {
      "title": "MatchLineup",
      "type": "object",
      "description": "The complete lineup for a match.",
      "properties": {
        "matchId": { "type": "string" },
        "teamOwnerId": { "type": "string" },
        "starters": { "type": "array", "items": { "type": "string" } },
        "substitutes": { "type": "array", "items": { "type": "string" } },
        "formation": { "type": "string" }
      },
      "required": ["matchId", "teamOwnerId", "starters", "substitutes"]
    },
    "PlayerMatchStat": {
      "title": "PlayerMatchStat",
      "type": "object",
      "description": "Individual stats for a player in a specific match.",
      "properties": {
        "matchId": { "type": "string" },
        "playerId": { "type": "string" },
        "teamOwnerId": { "type": "string" },
        "minutesPlayed": { "type": "number" },
        "goals": { "type": "number" },
        "assists": { "type": "number" },
        "yellowCards": { "type": "number" },
        "redCards": { "type": "number" }
      },
      "required": ["matchId", "playerId", "teamOwnerId"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/teams/{teamId}": {
      "schema": { "$ref": "#/backend/entities/Team" },
      "description": "Seasons/Teams collection."
    },
    "/teams/{teamId}/players/{playerId}": {
      "schema": { "$ref": "#/backend/entities/Player" },
      "description": "Players in a season."
    },
    "/teams/{teamId}/matches/{matchId}": {
      "schema": { "$ref": "#/backend/entities/Match" },
      "description": "Matches in a season."
    },
    "/teams/{teamId}/matches/{matchId}/events/{eventId}": {
      "schema": { "$ref": "#/backend/entities/MatchEvent" },
      "description": "Events for a match."
    },
    "/teams/{teamId}/matches/{matchId}/lineup/{lineupId}": {
      "schema": { "$ref": "#/backend/entities/MatchLineup" },
      "description": "Lineup for a match."
    },
    "/teams/{teamId}/matches/{matchId}/stats/{playerId}": {
      "schema": { "$ref": "#/backend/entities/PlayerMatchStat" },
      "description": "Individual performance stats."
    }
  }
}

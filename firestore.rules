rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADRA+ SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, collaborative sports team management model. 
     * It relies on Authorization Independence through denormalization.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /** 
     * @description Utilizza .get() per evitare errori se il campo è mancante.
     * Verifica ownerId (per le stagioni) o teamOwnerId (per i figli).
     */
    function hasAccess(data) {
      return isSignedIn() && (
        data.get('ownerId', '') == request.auth.uid || 
        data.get('teamOwnerId', '') == request.auth.uid || 
        (data.get('members', {})[request.auth.uid] != null) ||
        (data.get('teamMembers', {})[request.auth.uid] != null)
      );
    }

    function canModify(currentData) {
      return currentData != null && hasAccess(currentData);
    }

    // --- Collection Rules ---

    match /teams/{teamId} {
      // get e list sono permessi se l'utente è il proprietario o membro
      allow get, list: if isSignedIn() && (resource == null || hasAccess(resource.data));
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if canModify(resource.data);
      allow delete: if canModify(resource.data) && isOwner(resource.data.ownerId);

      match /players/{playerId} {
        allow get, list: if isSignedIn() && (resource == null || hasAccess(resource.data));
        allow create: if isSignedIn() && request.resource.data.teamOwnerId == request.auth.uid;
        allow update, delete: if canModify(resource.data);
      }

      match /matches/{matchId} {
        allow get, list: if isSignedIn() && (resource == null || hasAccess(resource.data));
        allow create: if isSignedIn() && request.resource.data.teamOwnerId == request.auth.uid;
        allow update, delete: if canModify(resource.data);

        match /stats/{playerMatchStatId} {
          allow get, list: if isSignedIn() && (resource == null || hasAccess(resource.data));
          allow create: if isSignedIn() && request.resource.data.teamOwnerId == request.auth.uid;
          allow update: if canModify(resource.data);
          allow delete: if canModify(resource.data);
        }

        match /lineup/{matchLineupId} {
          allow get, list: if isSignedIn() && (resource == null || hasAccess(resource.data));
          allow create: if isSignedIn() && request.resource.data.teamOwnerId == request.auth.uid;
          allow update: if canModify(resource.data);
          allow delete: if canModify(resource.data);
        }

        match /events/{eventId} {
          allow get, list: if isSignedIn() && (resource == null || hasAccess(resource.data));
          allow create: if isSignedIn() && request.resource.data.teamOwnerId == request.auth.uid;
          allow update: if canModify(resource.data);
          allow delete: if canModify(resource.data);
        }
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // Checks that the incoming document data sets teamOwnerId to the caller's UID
    // OR that the current user is in the sharedWith list of the parent season
    function incomingIsAuthorized(seasonId) {
      return isSignedIn() && (
        request.resource.data.teamOwnerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/teams/$(seasonId)).data.sharedWith ||
        get(/databases/$(database)/documents/teams/$(seasonId)).data.ownerId == request.auth.uid
      );
    }

    // Checks that the existing document is authorized for the caller
    function existingIsAuthorized(seasonId) {
      return isSignedIn() && (
        resource.data.teamOwnerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/teams/$(seasonId)).data.sharedWith ||
        get(/databases/$(database)/documents/teams/$(seasonId)).data.ownerId == request.auth.uid
      );
    }
    
    function isSeasonAuthorized(seasonId) {
      let season = get(/databases/$(database)/documents/teams/$(seasonId)).data;
      return isSignedIn() && (season.ownerId == request.auth.uid || request.auth.uid in season.sharedWith);
    }

    // ─── /users/{userId} ─────────────────────────────────────────────────────
    
    match /users/{userId} {
      allow get:    if isOwner(userId);
      allow list:   if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      match /scoutPlayers/{scoutPlayerId} {
        allow get, list: if isOwner(userId);
        allow create:    if isOwner(userId) && request.resource.data.id == scoutPlayerId;
        allow update:    if isOwner(userId);
        allow delete:    if isOwner(userId);
      }

      match /scoutCategories/{scoutCategoryId} {
        allow get, list: if isOwner(userId);
        allow create:    if isOwner(userId) && request.resource.data.id == scoutCategoryId;
        allow update:    if isOwner(userId);
        allow delete:    if isOwner(userId);
      }

      match /trainingSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create:    if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);

        match /attendance/{playerId} {
          allow get, list: if isOwner(userId);
          allow write:     if isOwner(userId);
        }
      }
    }

    // ─── /teams/{seasonId} ───────────────────────────────────────────────────
    
    match /teams/{seasonId} {
      allow get:    if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.sharedWith);
      allow list:   if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.sharedWith);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
                      (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWith']) && request.auth.uid in request.resource.data.sharedWith)
                    );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // ── Players ────────────────────────────────────────────────────────────
      match /players/{playerId} {
        allow get:    if isSignedIn() && (resource == null || isSeasonAuthorized(seasonId));
        allow list:   if isSignedIn() && isSeasonAuthorized(seasonId);
        allow create: if isSignedIn() && isSeasonAuthorized(seasonId);
        allow update: if isSignedIn() && isSeasonAuthorized(seasonId);
        allow delete: if isSignedIn() && isSeasonAuthorized(seasonId);
      }

      // ── Matches ───────────────────────────────────────────────────────────
      match /matches/{matchId} {
        allow get:    if isSignedIn() && (resource == null || isSeasonAuthorized(seasonId));
        allow list:   if isSignedIn() && isSeasonAuthorized(seasonId);
        allow create: if isSignedIn() && isSeasonAuthorized(seasonId);
        allow update: if isSignedIn() && isSeasonAuthorized(seasonId);
        allow delete: if isSignedIn() && isSeasonAuthorized(seasonId);

        match /lineup/{lineupId} {
          allow get:    if isSignedIn() && (resource == null || isSeasonAuthorized(seasonId));
          allow list:   if isSignedIn() && isSeasonAuthorized(seasonId);
          allow create: if isSignedIn() && isSeasonAuthorized(seasonId);
          allow update: if isSignedIn() && isSeasonAuthorized(seasonId);
          allow delete: if isSignedIn() && isSeasonAuthorized(seasonId);
        }

        match /events/{eventId} {
          allow get:    if isSignedIn() && (resource == null || isSeasonAuthorized(seasonId));
          allow list:   if isSignedIn() && isSeasonAuthorized(seasonId);
          allow create: if isSignedIn() && isSeasonAuthorized(seasonId);
          allow update: if isSignedIn() && isSeasonAuthorized(seasonId);
          allow delete: if isSignedIn() && isSeasonAuthorized(seasonId);
        }

        match /stats/{statId} {
          allow get:    if isSignedIn() && (resource == null || isSeasonAuthorized(seasonId));
          allow list:   if isSignedIn() && isSeasonAuthorized(seasonId);
          allow create: if isSignedIn() && isSeasonAuthorized(seasonId);
          allow update: if isSignedIn() && isSeasonAuthorized(seasonId);
          allow delete: if isSignedIn() && isSeasonAuthorized(seasonId);
        }
      }
    }

    // ─── /exercises/{exerciseId} ─────────────────────────────────────────────
    
    match /exercises/{exerciseId} {
      allow get, list: if isSignedIn() && (resource.data.visibility == 'global' || resource.data.userId == request.auth.uid);
      allow create:    if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

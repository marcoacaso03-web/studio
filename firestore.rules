
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // Checks that the incoming document data sets teamOwnerId to the caller's UID
    function incomingIsOwnedByMe() {
      return isSignedIn() && request.resource.data.teamOwnerId == request.auth.uid;
    }

    // Checks that the existing document is owned by the caller
    function existingIsOwnedByMe() {
      return isSignedIn() && resource.data.teamOwnerId == request.auth.uid;
    }

    // ─── /users/{userId} ─────────────────────────────────────────────────────
    // Personal user document and sub-collections (Scout, Training sessions)

    match /users/{userId} {
      allow get:    if isOwner(userId);
      allow list:   if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      match /scoutPlayers/{scoutPlayerId} {
        allow get, list: if isOwner(userId);
        allow create:    if isOwner(userId) && request.resource.data.id == scoutPlayerId;
        allow update:    if isOwner(userId);
        allow delete:    if isOwner(userId);
      }

      match /scoutCategories/{scoutCategoryId} {
        allow get, list: if isOwner(userId);
        allow create:    if isOwner(userId) && request.resource.data.id == scoutCategoryId;
        allow update:    if isOwner(userId);
        allow delete:    if isOwner(userId);
      }

      match /trainingSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create:    if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);

        match /attendance/{playerId} {
          allow get, list: if isOwner(userId);
          allow write:     if isOwner(userId);
        }
      }
    }

    // ─── /teams/{seasonId} ───────────────────────────────────────────────────
    // Season document: owned by the user who created it (ownerId field).
    // Sub-collections (players, matches, events, lineup) gated by teamOwnerId.

    match /teams/{seasonId} {
      // Only the owning user can read/write their own season document
      allow get:    if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list:   if isSignedIn() && resource.data.ownerId == request.auth.uid; // filtered server-side with where('ownerId','==',uid)
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // ── Players ────────────────────────────────────────────────────────────
      match /players/{playerId} {
        allow get:    if isSignedIn() && resource.data.teamOwnerId == request.auth.uid;
        allow list:   if existingIsOwnedByMe(); // filtered server-side with where('teamOwnerId','==',uid)
        allow create: if incomingIsOwnedByMe();
        allow update: if existingIsOwnedByMe() && incomingIsOwnedByMe();
        allow delete: if existingIsOwnedByMe();
      }

      // ── Matches ───────────────────────────────────────────────────────────
      match /matches/{matchId} {
        allow get:    if isSignedIn() && resource.data.teamOwnerId == request.auth.uid;
        allow list:   if existingIsOwnedByMe(); // filtered server-side with where('teamOwnerId','==',uid)
        allow create: if incomingIsOwnedByMe();
        allow update: if existingIsOwnedByMe() && incomingIsOwnedByMe();
        allow delete: if existingIsOwnedByMe();

        // ── Match Lineup ─────────────────────────────────────────────────
        match /lineup/{lineupId} {
          allow get:    if isSignedIn() && (!("teamOwnerId" in resource.data) || resource.data.teamOwnerId == request.auth.uid);
          allow list:   if existingIsOwnedByMe(); // filtered server-side with where('teamOwnerId','==',uid)
          allow create: if incomingIsOwnedByMe();
          allow update: if existingIsOwnedByMe() && incomingIsOwnedByMe();
          allow delete: if existingIsOwnedByMe();
        }

        // ── Match Events ─────────────────────────────────────────────────
        match /events/{eventId} {
          allow get:    if isSignedIn() && (!("teamOwnerId" in resource.data) || resource.data.teamOwnerId == request.auth.uid);
          allow list:   if existingIsOwnedByMe(); // filtered server-side with where('teamOwnerId','==',uid)
          allow create: if incomingIsOwnedByMe();
          allow update: if existingIsOwnedByMe() && incomingIsOwnedByMe();
          allow delete: if existingIsOwnedByMe();
        }

        // ── Match Stats ──────────────────────────────────────────────────
        match /stats/{statId} {
          allow get:    if isSignedIn() && (!("teamOwnerId" in resource.data) || resource.data.teamOwnerId == request.auth.uid);
          allow list:   if existingIsOwnedByMe(); // filtered server-side with where('teamOwnerId','==',uid)
          allow create: if incomingIsOwnedByMe();
          allow update: if existingIsOwnedByMe() && incomingIsOwnedByMe();
          allow delete: if existingIsOwnedByMe();
        }
      }
    }

    // ─── /exercises/{exerciseId} ─────────────────────────────────────────────
    // Training exercises library: visible if global OR if the caller is the owner.
    
    match /exercises/{exerciseId} {
      allow get, list: if isSignedIn() && (resource.data.visibility == 'global' || resource.data.userId == request.auth.uid);
      allow create:    if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // ─── Catch-all: deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
